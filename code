        // Export to Word using docx + FileSaver
        async function exportWord(data) {
            // ensure docx is loaded as window.docx
            const { Document, Packer, Paragraph, HeadingLevel, TextRun } = window.docx || {};
            if (!Document || !Packer || !Paragraph) {
                alert('docx library not loaded. Cannot export Word document.');
                return;
            }

            const children = [];

            // Title
            children.push(new Paragraph({
                text: data.title || 'SSOP',
                heading: HeadingLevel.TITLE
            }));

            // Area
            children.push(new Paragraph('Area: ' + (data.area || '')));

            children.push(new Paragraph(""));

            // Purpose
            children.push(new Paragraph({
                text: "Purpose",
                heading: HeadingLevel.HEADING_1
            }));
            children.push(new Paragraph(data.purpose || ''));

            // PPE Required
            children.push(new Paragraph({
                text: "PPE Required",
                heading: HeadingLevel.HEADING_1
            }));
            (data.ppeList || []).forEach(item => {
                if (item && item.trim()) {
                    children.push(new Paragraph("• " + item));
                }
            });

            // Tools Required
            children.push(new Paragraph({
                text: "Tools Required",
                heading: HeadingLevel.HEADING_1
            }));
            (data.toolsList || []).forEach(item => {
                if (item && item.trim()) {
                    children.push(new Paragraph("• " + item));
                }
            });

            // Specific Hazards
            children.push(new Paragraph({
                text: "Specific Hazards",
                heading: HeadingLevel.HEADING_1
            }));
            (data.hazardsList || []).forEach(item => {
                if (item && item.trim()) {
                    children.push(new Paragraph("• " + item));
                }
            });

            // Procedure Steps
            children.push(new Paragraph({
                text: "Procedure Steps",
                heading: HeadingLevel.HEADING_1
            }));

            (data.procedureSteps || []).forEach(step => {
                children.push(new Paragraph({
                    text: `${step.number}. ${step.title}`,
                    heading: HeadingLevel.HEADING_2
                }));
                if (step.description) children.push(new Paragraph(step.description));
                // Safety notes
                children.push(new Paragraph({
                    children: [
                        new TextRun({ text: "Safety Notes: ", bold: true }),
                        new TextRun(step.safetyNotes || '')
                    ]
                }));
                children.push(new Paragraph(""));
            });

            // Incident History
            children.push(new Paragraph({
                text: "Incident History",
                heading: HeadingLevel.HEADING_1
            }));

            (data.incidents || []).forEach(i => {
                const header = `${i.safetyNumber || ''} ${i.date ? ' ' + i.date : ''}`.trim();
                if (header) children.push(new Paragraph(header));
                if (i.description) children.push(new Paragraph(i.description));
                children.push(new Paragraph(""));
            });

            const doc = new Document({
                sections: [{
                    children
                }]
            });

            const blob = await Packer.toBlob(doc);
            saveAs(blob, (data.title || "SSOP") + ".docx");
        }

        // Save Document to localStorage and export to Word
        function saveDocument() {
            const data = {
                metadata: {},
                title: document.getElementById('titleInput').value,
                area: document.getElementById('areaInput').value,
                purpose: '',
                ppeList: [],
                toolsList: [],
                hazardsList: [],
                procedureSteps: [],
                incidents: [],
                ppeSelected: []
            };

            // Save metadata
            document.querySelectorAll('.metadata-input:not(.title-input):not(.area-input)').forEach((input, index) => {
                data.metadata[`field_${index}`] = input.value;
            });

            // Save purpose
            data.purpose = document.getElementById('purposeText').value;

            // Save PPE List
            document.querySelectorAll('#ppeList .list-input').forEach(input => {
                data.ppeList.push(input.value);
            });

            // Save Tools List
            document.querySelectorAll('#toolsList .list-input').forEach(input => {
                data.toolsList.push(input.value);
            });

            // Save Hazards List
            document.querySelectorAll('#hazardsList .list-input').forEach(input => {
                data.hazardsList.push(input.value);
            });

            // Save Procedure Steps
            document.querySelectorAll('.procedure-step').forEach((step, index) => {
                const title = step.querySelector('.procedure-title-input').value;
                const description = step.querySelectorAll('.detail-textarea')[0].value;
                const safetyNotes = step.querySelectorAll('.detail-textarea')[1].value;
                const images = [];

                step.querySelectorAll('.image-preview img').forEach(img => {
                    images.push(img.src);
                });

                data.procedureSteps.push({
                    number: index + 1,
                    title: title,
                    description: description,
                    safetyNotes: safetyNotes,
                    images: images
                });
            });

            // Save Incidents
            document.querySelectorAll('.incident-item').forEach(item => {
                const inputs = item.querySelectorAll('.incident-input');
                data.incidents.push({
                    safetyNumber: inputs[0].value,
                    date: inputs[1].value,
                    description: inputs[2].value
                });
            });

            // Save selected PPE icons
            document.querySelectorAll('.ppe-icon.selected').forEach(icon => {
                data.ppeSelected.push(icon.querySelector('.icon-label').textContent);
            });

            localStorage.setItem('ssop_document', JSON.stringify(data));

            // Export to Word
            exportWord(data);

            alert("✓ Document saved successfully.");
        }

        // Clear All Fields
        function clearAllFields() {
            if (confirm('Are you sure you want to clear all fields?')) {
                document.querySelectorAll('input, textarea').forEach(el => el.value = '');
                document.getElementById('titleInput').value = 'Title of SSOP';
                document.getElementById('areaInput').value = 'Area (Paper Mill, Primary, Material Handling)';
                document.getElementById('displayTitle').textContent = 'Title of SSOP';
                document.getElementById('displayArea').textContent = 'Area (Paper Mill, Primary, Material Handling)';
                document.querySelectorAll('.ppe-icon').forEach(el => el.classList.remove('selected'));
                document.querySelectorAll('.image-preview').forEach(el => el.remove());
                if (recognition) recognition.stop();
                if (aiRecognition) aiRecognition.stop();
                if (stepsRecognition) {
                    try { stepsRecognition.stop(); } catch (e) {}
                }
                localStorage.removeItem('ssop_document');
            }
        }

        // Load Document from localStorage on page load
        window.addEventListener('DOMContentLoaded', () => {
            const saved = localStorage.getItem('ssop_document');
            if (saved) {
                const data = JSON.parse(saved);

                // Load title and area
                if (data.title) {
                    document.getElementById('titleInput').value = data.title;
                    document.getElementById('displayTitle').textContent = data.title;
                }
                if (data.area) {
                    document.getElementById('areaInput').value = data.area;
                    document.getElementById('displayArea').textContent = data.area;
                }

                // Load metadata
                let metadataIndex = 0;
                document.querySelectorAll('.metadata-input:not(.title-input):not(.area-input)').forEach((input) => {
                    if (data.metadata && data.metadata[`field_${metadataIndex}`]) {
                        input.value = data.metadata[`field_${metadataIndex}`];
                    }
                    metadataIndex++;
                });

                // Load purpose
                if (data.purpose) {
                    document.getElementById('purposeText').value = data.purpose;
                }

                // Load PPE List
                document.querySelectorAll('#ppeList .list-input').forEach((input, index) => {
                    if (data.ppeList && data.ppeList[index]) {
                        input.value = data.ppeList[index];
                    }
                });

                // Load Tools List
                document.querySelectorAll('#toolsList .list-input').forEach((input, index) => {
                    if (data.toolsList && data.toolsList[index]) {
                        input.value = data.toolsList[index];
                    }
                });

                // Load Hazards List
                document.querySelectorAll('#hazardsList .list-input').forEach((input, index) => {
                    if (data.hazardsList && data.hazardsList[index]) {
                        input.value = data.hazardsList[index];
                    }
                });

                // Load Procedure Steps
                const stepsContainer = document.getElementById('stepsList');
                if (data.procedureSteps && data.procedureSteps.length > 0) {
                    stepsContainer.innerHTML = '';
                    data.procedureSteps.forEach((step, index) => {
                        const newStep = document.createElement('div');
                        newStep.className = 'procedure-step';
                        newStep.innerHTML = `
                            <div class="procedure-header">
                                <span class="procedure-number">${step.number}.</span>
                                <input type="text" class="procedure-title-input" placeholder="Enter procedure step title..." value="${(step.title||'').replace(/"/g, '&quot;')}">
                                <div class="procedure-controls">
                                    <button class="procedure-stt-btn" onclick="startProcedureStepSpeechToText(this)">🎤 Speak</button>
                                    <button class="toggle-detail-btn" onclick="toggleDetails(this)"></button>
                                </div>
                                <button class="remove-item-btn" onclick="removeProcedureStep(this)">Remove</button>
                            </div>
                            <div class="procedure-details">
                                <div class="detail-section">
                                    <div class="detail-label">Description:</div>
                                    <textarea class="detail-textarea" placeholder="Enter detailed description of this step...">${(step.description||'')}</textarea>
                                </div>
                                <div class="detail-section">
                                    <div class="detail-label">Safety Notes:</div>
                                    <textarea class="detail-textarea" placeholder="Enter any safety considerations for this step...">${(step.safetyNotes||'')}</textarea>
                                </div>
                                <div class="detail-section">
                                    <div class="detail-label">Images/Photos:</div>
                                    <div class="image-upload-section">
                                        <button class="image-upload-btn" onclick="triggerImageUpload(this)">📸 Add Image</button>
                                        <input type="file" class="hidden-file-input" accept="image/*" onchange="handleImageUpload(this)">
                                        <div class="image-preview-container"></div>
                                    </div>
                                </div>
                            </div>
                        `;
                        stepsContainer.appendChild(newStep);

                        // Load images
                        if (step.images && step.images.length > 0) {
                            const previewContainer = newStep.querySelector('.image-preview-container');
                            step.images.forEach(imgSrc => {
                                const preview = document.createElement('div');
                                preview.className = 'image-preview';
                                preview.innerHTML = `
                                    <img src="${imgSrc}" alt="preview">
                                    <button class="image-remove-btn" onclick="this.parentElement.remove()">✕</button>
                                `;
                                previewContainer.appendChild(preview);
                            });
                        }
                    });
                }

                // Load Incidents
                const incidentsContainer = document.getElementById('incidentsList');
                if (data.incidents && data.incidents.length > 0) {
                    incidentsContainer.innerHTML = '';
                    data.incidents.forEach(incident => {
                        const newItem = document.createElement('div');
                        newItem.className = 'incident-item';
                        newItem.innerHTML = `
                            <input type="text" class="incident-input" placeholder="IndustrySafe # (FYXX-XXXX)" value="${(incident.safetyNumber||'').replace(/"/g,'&quot;')}">
                            <input type="date" class="incident-input" value="${incident.date||''}">
                            <input type="text" class="incident-input" placeholder="Short description of incident" value="${(incident.description||'').replace(/"/g,'&quot;')}">
                            <button class="remove-item-btn" onclick="removeItem(this)">Remove</button>
                        `;
                        incidentsContainer.appendChild(newItem);
                    });
                }

                // Load selected PPE icons
                if (data.ppeSelected && data.ppeSelected.length > 0) {
                    document.querySelectorAll('.ppe-icon').forEach(icon => {
                        const label = icon.querySelector('.icon-label').textContent;
                        if (data.ppeSelected.includes(label)) {
                            icon.classList.add('selected');
                        }
                    });
                }
            }
        });

        // -------------------- Record All Steps feature --------------------
        let stepsRecognition = null;
        let isRecordingAllSteps = false;
        let currentRecordingStep = 0;
        let stepsBuffer = '';

        // Start/stop toggle
        function toggleRecordAllSteps() {
            if (!window.SpeechRecognition && !window.webkitSpeechRecognition) {
                alert('Speech Recognition not supported in your browser.');
                return;
            }
            if (isRecordingAllSteps) {
                stopRecordingAllSteps();
            } else {
                startRecordingAllSteps();
            }
        }

        function startRecordingAllSteps() {
            const btn = document.getElementById('recordAllStepsBtn');
            btn.classList.add('recording');
            btn.textContent = '⏹️ Stop Recording';
            isRecordingAllSteps = true;

            // initialize recognition
            const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
            stepsRecognition = new SR();
            stepsRecognition.continuous = true;        // allow longer continuous recording
            stepsRecognition.interimResults = true;
            stepsRecognition.lang = 'en-US';

            // start at the first step (or current)
            const steps = document.querySelectorAll('.procedure-step');
            if (steps.length === 0) {
                alert('No procedure steps found. Add at least one step first.');
                stopRecordingAllSteps();
                return;
            }
            currentRecordingStep = 0;
            stepsBuffer = '';

            addAIMessage(`🔴 Recording steps - speak step ${currentRecordingStep + 1}. Say "next" to go to the next step, or "stop" to finish.`);

            stepsRecognition.onresult = (event) => {
                // accumulate transcripts; handle final results for parsing
                let interim = '';
                let finalText = '';
                for (let i = event.resultIndex; i < event.results.length; i++) {
                    const t = event.results[i][0].transcript;
                    if (event.results[i].isFinal) {
                        finalText += t + ' ';
                    } else {
                        interim += t;
                    }
                }

                // Combine into buffer (final results appended permanently; interim only shown)
                if (finalText.trim()) {
                    stepsBuffer += finalText.trim() + ' ';
                    // after finalText appended, check for control keywords
                    handleBufferForCommands();
                }

                // Optionally show interim text in AI input for visibility
                const aiInput = document.getElementById('aiInput');
                if (aiInput) aiInput.value = (stepsBuffer + interim).trim();
                lastTranscript = (stepsBuffer + interim).trim();
            };

            stepsRecognition.onerror = (e) => {
                console.error('stepsRecognition error', e);
            };

            stepsRecognition.onend = () => {
                // If we ended unexpectedly while still in recording mode, try to restart (some browsers stop automatically)
                if (isRecordingAllSteps) {
                    try {
                        stepsRecognition.start();
                    } catch (err) {
                        console.warn('Could not restart stepsRecognition', err);
                        stopRecordingAllSteps();
                    }
                }
            };

            try {
                stepsRecognition.start();
            } catch (e) {
                console.warn('stepsRecognition.start error', e);
            }
        }

        function stopRecordingAllSteps() {
            isRecordingAllSteps = false;
            if (stepsRecognition) {
                try { stepsRecognition.stop(); } catch (e) { /* ignore */ }
                stepsRecognition = null;
            }
            const btn = document.getElementById('recordAllStepsBtn');
            if (btn) {
                btn.classList.remove('recording');
                btn.textContent = '🎤 Record All Steps';
            }
            // If any buffered text left, finalize it into the current step
            if (stepsBuffer.trim()) {
                finalizeBufferIntoStep(stepsBuffer.trim(), currentRecordingStep);
                stepsBuffer = '';
            }
            addAIMessage('🟢 Finished recording all steps.');
        }

        // Inspect buffer for "next" or "next step" or "stop"/"done" commands
        function handleBufferForCommands() {
            const check = stepsBuffer.toLowerCase();
            // If user said "stop" or "done", end recording completely
            if (/\b(stop|done|finish|that's all|that's it)\b/.test(check)) {
                // remove the command word from content
                stepsBuffer = stepsBuffer.replace(/\b(stop|done|finish|that's all|that's it)\b/gi, ' ');
                finalizeBufferIntoStep(stepsBuffer.trim(), currentRecordingStep);
                stepsBuffer = '';
                stopRecordingAllSteps();
                return;
            }

            // If user said "next" or "next step", move to next step
            if (/\b(next step|next)\b/.test(check)) {
                // remove "next" command from buffer and finalize
                stepsBuffer = stepsBuffer.replace(/\b(next step|next)\b/gi, ' ');
                finalizeBufferIntoStep(stepsBuffer.trim(), currentRecordingStep);
                stepsBuffer = '';
                moveToNextRecordingStep();
            }
        }

        // Move focus to next step or stop if none
        function moveToNextRecordingStep() {
            const steps = document.querySelectorAll('.procedure-step');
            currentRecordingStep++;
            if (currentRecordingStep >= steps.length) {
                addAIMessage('Reached last step — stopping recording.');
                stopRecordingAllSteps();
            } else {
                addAIMessage(`📝 Now recording step ${currentRecordingStep + 1}. Say "next" when finished with this step.`);
            }
        }

        // Parse buffer text into title/description/safety notes heuristics and fill step DOM
        function finalizeBufferIntoStep(bufferText, stepIndex) {
            if (!bufferText || !bufferText.trim()) return;
            const steps = document.querySelectorAll('.procedure-step');
            if (stepIndex >= steps.length) return;
            const stepEl = steps[stepIndex];

            // Try to parse labeled sections: title:, description:, safety notes:
            const titleMatch = /title[:\-]\s*([\s\S]*?)(?=(description[:\-]|safety notes[:\-]|$))/i.exec(bufferText);
            const descMatch = /description[:\-]\s*([\s\S]*?)(?=(safety notes[:\-]|title[:\-]|$))/i.exec(bufferText);
            const safetyMatch = /safety notes[:\-]\s*([\s\S]*?)(?=(description[:\-]|title[:\-]|$))/i.exec(bufferText);

            let title = titleMatch ? titleMatch[1].trim() : '';
            let description = descMatch ? descMatch[1].trim() : '';
            let safetyNotes = safetyMatch ? safetyMatch[1].trim() : '';

            // If no explicit labels, heuristics:
            if (!title && !description && !safetyNotes) {
                // split by sentence boundaries (simple)
                const sentences = bufferText.split(/(?<=[.?!])\s+/).map(s => s.trim()).filter(Boolean);
                if (sentences.length === 1) {
                    // single sentence -> put into description, and if it's short use as title
                    if (sentences[0].split(/\s+/).length <= 8) title = sentences[0];
                    else description = sentences[0];
                } else if (sentences.length >= 2) {
                    // first short sentence -> title, rest -> description
                    if (sentences[0].split(/\s+/).length <= 10) {
                        title = sentences[0];
                        description = sentences.slice(1).join(' ');
                    } else {
                        description = sentences.join(' ');
                    }
                } else {
                    description = bufferText;
                }
            }

            // Fill DOM fields
            const titleInput = stepEl.querySelector('.procedure-title-input');
            const descriptionTextarea = stepEl.querySelectorAll('.detail-textarea')[0]; // description
            const safetyTextarea = stepEl.querySelectorAll('.detail-textarea')[1]; // safety notes

            if (title && titleInput) {
                // append to preserve existing manual content
                titleInput.value = (titleInput.value ? titleInput.value + ' ' + title : title);
            }
            if (description && descriptionTextarea) {
                descriptionTextarea.value = (descriptionTextarea.value ? descriptionTextarea.value + '\n' + description : description);
            }
            if (safetyNotes && safetyTextarea) {
                safetyTextarea.value = (safetyTextarea.value ? safetyTextarea.value + '\n' + safetyNotes : safetyNotes);
            }

            addAIMessage(`✓ Filled step ${stepIndex + 1}`);
        }
        // -------------------- End Record All Steps --------------------

    </script>
