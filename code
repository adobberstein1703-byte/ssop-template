    <script>
        // AI Assistant functionality
        let aiMessages = [];
        let lastTranscript = '';
        let aiRecognition = null;
        let aiRecordingMode = false;

        // Setup AI speech recognition
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        if (SpeechRecognition) {
            aiRecognition = new SpeechRecognition();

            // Increase allowed speaking time by enabling continuous mode for the AI assistant
            aiRecognition.continuous = true;
            aiRecognition.interimResults = true;
            aiRecognition.lang = 'en-US';
            aiRecognition.maxAlternatives = 1;

            aiRecognition.onstart = () => {
                aiRecordingMode = true;
                const btn = document.getElementById('aiSpeakBtn');
                btn.classList.add('recording');
                btn.textContent = '⏹️ Recording';
            };

            aiRecognition.onresult = (event) => {
                let interimTranscript = '';
                let finalTranscript = '';

                for (let i = event.resultIndex; i < event.results.length; i++) {
                    const transcript = event.results[i][0].transcript;
                    if (event.results[i].isFinal) {
                        finalTranscript += transcript + ' ';
                    } else {
                        interimTranscript += transcript;
                    }
                }

                const text = finalTranscript || interimTranscript;
                document.getElementById('aiInput').value = text;
                lastTranscript = text.trim();
            };

            aiRecognition.onend = () => {
                // In continuous mode, some browsers stop automatically; toggle recording flag and UI
                aiRecordingMode = false;
                const btn = document.getElementById('aiSpeakBtn');
                btn.classList.remove('recording');
                btn.textContent = '🎤 Speak';
            };

            aiRecognition.onerror = (event) => {
                console.error('AI Speech error:', event.error);
                const btn = document.getElementById('aiSpeakBtn');
                btn.classList.remove('recording');
                btn.textContent = '🎤 Speak';
                aiRecordingMode = false;
            };
        }

        function startAISpeechToText() {
            if (!aiRecognition) {
                alert('Speech Recognition not supported');
                return;
            }

            if (aiRecordingMode) {
                aiRecognition.stop();
            } else {
                try {
                    aiRecognition.start();
                } catch (e) {
                    console.warn('aiRecognition.start() error', e);
                }
            }
        }

        function toggleAIPanel() {
            const panel = document.querySelector('.ai-assistant-panel');
            const isMinimized = panel.style.height === '50px';

            if (isMinimized) {
                panel.style.height = 'auto';
                document.querySelector('.ai-assistant-content').style.display = 'flex';
                document.querySelector('.ai-input-section').style.display = 'flex';
            } else {
                panel.style.height = '50px';
                document.querySelector('.ai-assistant-content').style.display = 'none';
                document.querySelector('.ai-input-section').style.display = 'none';
            }
        }

        function addAIMessage(message, isUser = false) {
            const messagesDiv = document.getElementById('aiMessages');
            const messageEl = document.createElement('div');
            messageEl.className = `ai-message ${isUser ? 'user' : 'assistant'}`;
            messageEl.textContent = message;
            messagesDiv.appendChild(messageEl);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }

        function handleAIInput(event) {
            if (event.key === 'Enter') {
                sendAIMessage();
            }
        }

        function sendAIMessage() {
            const input = document.getElementById('aiInput');
            const message = input.value.trim();

            if (!message) return;

            addAIMessage(message, true);
            input.value = '';

            // Process AI request (simple command parser)
            const lowerMessage = message.toLowerCase();

            if (lowerMessage.includes('speak') || lowerMessage.includes('record all') || lowerMessage.includes('auto-fill')) {
                speakAndFillAllFields();
            } else if (lowerMessage.includes('fix') || lowerMessage.includes('spell')) {
                fixSpellingErrors();
            } else if (lowerMessage.includes('transcript') || lowerMessage.includes('place')) {
                placeTranscript();
            } else if (lowerMessage.includes('clean') || lowerMessage.includes('format')) {
                cleanText();
            } else if (lowerMessage.includes('help')) {
                addAIMessage('I can help you with:\n• "speak and fill" - Record and auto-fill all fields\n• "fix spelling" - Correct spelling errors\n• "place transcript" - Put saved transcript in a field\n• "clean text" - Format and clean text\n• "last transcript" - Show last recognized text');
            } else if (lowerMessage.includes('last transcript')) {
                addAIMessage(`Last transcript: "${lastTranscript}"`);
            } else {
                addAIMessage('I can help with speaking/recording, spelling fixes, placing transcripts, and cleaning text. What would you like me to do?');
            }
        }

        function speakAndFillAllFields() {
            addAIMessage('Starting auto-fill mode. I\'ll record and place text in each field. Press the speak button in the AI panel and start speaking!');

            const allFields = document.querySelectorAll('textarea, .list-input, .procedure-title-input');

            if (allFields.length === 0) {
                addAIMessage('No fields found to fill.');
                return;
            }

            let currentFieldIndex = 0;

            function recordNextField() {
                if (currentFieldIndex >= allFields.length) {
                    addAIMessage('✓ Finished filling all fields!');
                    return;
                }

                const field = allFields[currentFieldIndex];
                const fieldName = field.placeholder || field.id || 'Field ' + (currentFieldIndex + 1);

                addAIMessage(`📝 Now fill: ${fieldName}`);

                const recognitionInstance = new (window.SpeechRecognition || window.webkitSpeechRecognition)();
                recognitionInstance.continuous = false;
                recognitionInstance.interimResults = true;
                recognitionInstance.lang = 'en-US';

                recognitionInstance.onresult = (event) => {
                    let finalTranscript = '';
                    for (let i = event.resultIndex; i < event.results.length; i++) {
                        if (event.results[i].isFinal) {
                            finalTranscript += event.results[i][0].transcript + ' ';
                        }
                    }

                    if (finalTranscript.trim()) {
                        field.value = finalTranscript.trim();
                        lastTranscript = finalTranscript.trim();
                        currentFieldIndex++;

                        setTimeout(() => {
                            recordNextField();
                        }, 500);
                    }
                };

                recognitionInstance.onerror = () => {
                    // move on to next field on error
                    currentFieldIndex++;
                    recordNextField();
                };

                try {
                    recognitionInstance.start();
                } catch (e) {
                    console.warn('recognitionInstance.start() error', e);
                }
            }

            recordNextField();
        }

        function fixSpellingErrors() {
            addAIMessage('Scanning for spelling errors...');

            const corrections = {
                'recieve': 'receive',
                'occured': 'occurred',
                'teh': 'the',
                'thier': 'their',
                'wich': 'which',
                'writting': 'writing',
                'seperete': 'separate',
                'definitly': 'definitely',
                'untill': 'until',
                'accomodate': 'accommodate',
                'bussiness': 'business',
                'comming': 'coming',
                'desend': 'descend',
                'exellent': 'excellent'
            };

            let fixedCount = 0;

            document.querySelectorAll('input, textarea').forEach(field => {
                let text = field.value;
                let originalText = text;

                Object.entries(corrections).forEach(([wrong, correct]) => {
                    const regex = new RegExp(`\\b${wrong}\\b`, 'gi');
                    text = text.replace(regex, correct);
                });

                if (text !== originalText) {
                    field.value = text;
                    fixedCount++;
                }
            });

            if (fixedCount > 0) {
                addAIMessage(`✓ Fixed ${fixedCount} field(s) with spelling corrections!`);
            } else {
                addAIMessage('No spelling errors detected.');
            }
        }

        function placeTranscript() {
            if (!lastTranscript) {
                addAIMessage('No transcript available. Please record some speech first.');
                return;
            }

            const purposeText = document.getElementById('purposeText');
            if (purposeText && !purposeText.value) {
                purposeText.value = lastTranscript;
                addAIMessage(`✓ Placed transcript in Purpose field!`);
                return;
            }

            const lastPPEInput = document.querySelector('#ppeList .list-input:last-child');
            if (lastPPEInput && !lastPPEInput.value) {
                lastPPEInput.value = lastTranscript;
                addAIMessage(`✓ Placed transcript in PPE field!`);
                return;
            }

            addAIMessage('Placed transcript in the first empty field found.');
            // fallback: place in first empty text input or textarea
            const firstEmptyText = Array.from(document.querySelectorAll('input[type="text"], textarea')).find(el => !el.value);
            if (firstEmptyText) {
                firstEmptyText.value = lastTranscript;
            }
        }

        function cleanText() {
            addAIMessage('Cleaning text in all fields...');

            let cleanedCount = 0;

            document.querySelectorAll('input[type="text"], textarea').forEach(field => {
                let text = field.value;
                let cleaned = text
                    .trim()
                    .replace(/\s+/g, ' ')
                    .replace(/\n+/g, '\n');

                if (text !== cleaned) {
                    field.value = cleaned;
                    cleanedCount++;
                }
            });

            addAIMessage(`✓ Cleaned ${cleanedCount} field(s)!`);
        }

        // Speech to Text setup for form fields
        let recognition = null;
        let currentTarget = null;
        let currentButton = null;
        let isFieldRecognitionActive = false;

        if (SpeechRecognition) {
            recognition = new SpeechRecognition();
            // Allow longer per-field speech by enabling continuous for form-field recognition too
            recognition.continuous = true;
            recognition.interimResults = true;
            recognition.lang = 'en-US';

            recognition.onstart = () => {
                isFieldRecognitionActive = true;
                if (currentButton) {
                    currentButton.classList.add('recording');
                    currentButton.textContent = '⏹️ Stop Recording';
                }
            };

            recognition.onresult = (event) => {
                let interimTranscript = '';
                let finalTranscript = '';

                for (let i = event.resultIndex; i < event.results.length; i++) {
                    const transcript = event.results[i][0].transcript;

                    if (event.results[i].isFinal) {
                        finalTranscript += transcript + ' ';
                    } else {
                        interimTranscript += transcript;
                    }
                }

                const text = finalTranscript || interimTranscript;
                lastTranscript = text.trim();

                if (currentTarget) {
                    currentTarget.value = (currentTarget.value + ' ' + text).trim();
                }
            };

            recognition.onend = () => {
                isFieldRecognitionActive = false;
                if (currentButton) {
                    currentButton.classList.remove('recording');
                    currentButton.textContent = '🎤 Speak';
                }
            };

            recognition.onerror = (event) => {
                console.error('Speech recognition error:', event.error);
                if (currentButton) {
                    currentButton.classList.remove('recording');
                    currentButton.textContent = '🎤 Speak';
                }
                isFieldRecognitionActive = false;
            };
        }

        // Purpose Speech to Text
        function startPurposeSpeechToText() {
