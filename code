}
    <div class="container">
        <!-- Header -->
        <div class="header">
            <div class="logo">📋</div>
            <div class="page-indicator">Page 1 of 3</div>
        </div>

        <!-- Title Section -->
        <div class="title-section">
            <h1 id="displayTitle">Title of SSOP</h1>
            <p id="displayArea">Area (Paper Mill, Primary, Material Handling)</p>
        </div>

        <!-- Metadata -->
        <div class="metadata-grid">
            <div class="metadata-item">
                <span class="metadata-label">Department:</span>
                <input type="text" class="metadata-input" placeholder="SSOP">
            </div>
            <div class="metadata-item">
                <span class="metadata-label">Reviewed:</span>
                <input type="date" class="metadata-input">
            </div>
            <div class="metadata-item">
                <span class="metadata-label">Document Type:</span>
                <input type="text" class="metadata-input" placeholder="SSOP">
            </div>
            <div class="metadata-item">
                <span class="metadata-label">Revised:</span>
                <input type="date" class="metadata-input">
            </div>
            <div class="metadata-item">
                <span class="metadata-label">Document #:</span>
                <input type="text" class="metadata-input">
            </div>
            <div class="metadata-item">
                <span class="metadata-label">Revision #:</span>
                <input type="number" class="metadata-input" value="1">
            </div>
            <div class="metadata-item">
                <span class="metadata-label">Approved by:</span>
                <input type="text" class="metadata-input">
            </div>
            <div class="metadata-item">
                <span class="metadata-label">Created:</span>
                <input type="date" class="metadata-input">
            </div>
            <div class="metadata-item" style="grid-column: 1/-1;">
                <span class="metadata-label">Title:</span>
                <input type="text" class="metadata-input title-input" id="titleInput" placeholder="Enter title here..." value="Title of SSOP">
            </div>
            <div class="metadata-item" style="grid-column: 1/-1;">
                <span class="metadata-label">Area:</span>
                <input type="text" class="metadata-input area-input" id="areaInput" placeholder="Enter area here..." value="Area (Paper Mill, Primary, Material Handling)">
            </div>
        </div>

        <!-- Purpose Section -->
        <div class="section">
            <div class="section-header">
                <div class="section-title-text">Purpose:</div>
                <button class="speech-to-text-btn" id="purposeSTTBtn" onclick="startPurposeSpeechToText()">🎤 Speak</button>
            </div>
            <textarea class="text-input" id="purposeText" rows="4" placeholder="Enter the purpose of this SSOP..."></textarea>
        </div>

        <!-- PPE Section -->
        <div class="section">
            <div class="section-title">PPE Required (Click to Select):</div>
            <div class="ppe-icons">
                <div class="ppe-icon" onclick="togglePPE(this)">
                    <div class="icon-circle">👢</div>
                    <div class="icon-label">Foot Protection</div>
                </div>
                <div class="ppe-icon" onclick="togglePPE(this)">
                    <div class="icon-circle">😷</div>
                    <div class="icon-label">Dust Mask</div>
                </div>
                <div class="ppe-icon" onclick="togglePPE(this)">
                    <div class="icon-circle">🛡️</div>
                    <div class="icon-label">Face Shield</div>
                </div>
                <div class="ppe-icon" onclick="togglePPE(this)">
                    <div class="icon-circle">👓</div>
                    <div class="icon-label">Safety Glasses</div>
                </div>
                <div class="ppe-icon" onclick="togglePPE(this)">
                    <div class="icon-circle">🤖</div>
                    <div class="icon-label">Hard Hat</div>
                </div>
                <div class="ppe-icon" onclick="togglePPE(this)">
                    <div class="icon-circle">🧤</div>
                    <div class="icon-label">Hand Protection</div>
                </div>
                <div class="ppe-icon" onclick="togglePPE(this)">
                    <div class="icon-circle">🪂</div>
                    <div class="icon-label">Fall Protection</div>
                </div>
                <div class="ppe-icon" onclick="togglePPE(this)">
                    <div class="icon-circle">⚡</div>
                    <div class="icon-label">Welding Mask</div>
                </div>
                <div class="ppe-icon" onclick="togglePPE(this)">
                    <div class="icon-circle">👕</div>
                    <div class="icon-label">Hi-Visibility Clothing</div>
                </div>
                <div class="ppe-icon" onclick="togglePPE(this)">
                    <div class="icon-circle">🧥</div>
                    <div class="icon-label">Protective Clothing</div>
                </div>
                <div class="ppe-icon" onclick="togglePPE(this)">
                    <div class="icon-circle">💨</div>
                    <div class="icon-label">Respirators</div>
                </div>
                <div class="ppe-icon" onclick="togglePPE(this)">
                    <div class="icon-circle">🎒</div>
                    <div class="icon-label">Breathing Apparatus</div>
                </div>
            </div>
        </div>

        <!-- PPE Required List -->
        <div class="section">
            <div class="section-header">
                <div class="section-title-text">PPE Required (Detailed List):</div>
                <button class="speech-to-text-btn" id="ppeSTTBtn" onclick="startPPESpeechToText()">🎤 Speak</button>
            </div>
            <div class="list-section" id="ppeList">
                <div class="list-item">
                    <span class="list-number">1.</span>
                    <input type="text" class="list-input" placeholder="Enter PPE item...">
                    <button class="remove-item-btn" onclick="removeItem(this)">Remove</button>
                </div>
            </div>
            <button class="add-item-btn" onclick="addPPEItem()">+ Add PPE Item</button>
        </div>

        <!-- Specific Tools Section -->
        <div class="section">
            <div class="section-header">
                <div class="section-title-text">Specific Tools Required:</div>
                <button class="speech-to-text-btn" id="toolsSTTBtn" onclick="startToolsSpeechToText()">🎤 Speak</button>
            </div>
            <div class="list-section" id="toolsList">
                <div class="list-item">
                    <span class="list-number">•</span>
                    <input type="text" class="list-input" placeholder="Enter tool...">
                    <button class="remove-item-btn" onclick="removeItem(this)">Remove</button>
                </div>
            </div>
            <button class="add-item-btn" onclick="addToolItem()">+ Add Tool</button>
        </div>

        <!-- Specific Hazards Section -->
        <div class="section">
            <div class="section-header">
                <div class="section-title-text">Specific Hazards:</div>
                <button class="speech-to-text-btn" id="hazardsSTTBtn" onclick="startHazardsSpeechToText()">🎤 Speak</button>
            </div>
            <div class="list-section" id="hazardsList">
                <div class="list-item">
                    <span class="list-number">•</span>
                    <input type="text" class="list-input" placeholder="Enter hazard...">
                    <button class="remove-item-btn" onclick="removeItem(this)">Remove</button>
                </div>
            </div>
            <button class="add-item-btn" onclick="addHazardItem()">+ Add Hazard</button>
        </div>

        <!-- Procedure Steps Section -->
        <div class="section">
            <div class="section-title">Procedure Steps:</div>
            <div class="list-section" id="stepsList">
                <div class="procedure-step">
                    <div class="procedure-header">
                        <span class="procedure-number">1.</span>
